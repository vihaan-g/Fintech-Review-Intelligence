{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/secrets_check.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'printf %s "$CLAUDE_TOOL_INPUT_PATH" | grep -q "^src/" && python3 -m pytest tests/ -x -q || true'",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
