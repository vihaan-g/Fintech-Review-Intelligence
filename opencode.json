{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "CLAUDE.md",
    ".claude/rules/common/*.md",
    ".claude/rules/python/*.md"
  ],
  "agent": {
    "build": {
      "permission": {
        "task": {
          "*": "ask",
          "data-collector": "allow",
          "sql-analyst": "allow",
          "council-orchestrator": "allow",
          "insight-reporter": "allow"
        }
      }
    },
    "plan": {
      "permission": {
        "task": {
          "*": "ask",
          "data-collector": "allow",
          "sql-analyst": "allow",
          "council-orchestrator": "allow",
          "insight-reporter": "allow"
        },
        "skill": {
          "*": "allow"
        }
      }
    }
  }
}
